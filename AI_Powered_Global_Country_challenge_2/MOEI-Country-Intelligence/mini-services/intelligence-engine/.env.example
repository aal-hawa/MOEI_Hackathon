# Default provider: OpenAI (swap to Core42 / Compass later via config/models.yaml)
OPENAI_API_KEY=
# Optional: point at any OpenAI-compatible gateway (Core42 Compass, a LiteLLM proxy, Azure, etc.)
# For direct OpenAI: https://api.openai.com/v1
# For Z SDK WEB proxy (works in all regions): http://localhost:3040/v1
OPENAI_API_BASE=http://localhost:3040/v1

# Where the SQLite Library lives
LIBRARY_DB_PATH=./data/library.db