TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Gulf Arabic / UAE voice for the officer call.
# Use Polly.Hala-Neural or Polly.Zayd-Neural.
TWILIO_AR_VOICE=Polly.Hala-Neural

# Optional premium Emirati-accent voice path.
# Create/select an ElevenLabs voice with an Emirati/Gulf Arabic accent, then paste its voice ID.
# Leave ELEVENLABS_ENABLED=false for Twilio's Arabic fallback.
# Set it to true only when your ElevenLabs plan/voice can be used through the API.
ELEVENLABS_ENABLED=false
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your_emirati_voice_id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Required if the officer should decide from inside the phone call.
# For local testing, run: ngrok http 3001
# Then set this to the HTTPS forwarding URL, for example:
# TWILIO_WEBHOOK_BASE_URL=https://abc123.ngrok-free.app
# TWILIO_WEBHOOK_SECRET=use_a_random_local_secret_or_leave_unset_to_use_auth_token

# Optional: callback URL for carrier call status events.
# TWILIO_STATUS_CALLBACK_URL=https://your-public-url.example/api/twilio/status
